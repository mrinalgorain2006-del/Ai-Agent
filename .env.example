# ═══════════════════════════════════════════════════════════════════════════════
# 🔐 ENVIRONMENT VARIABLES - SECURITY CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
# 
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env file to version control!
#

# 🔑 AUTHENTICATION CREDENTIALS
# Set your secure admin username and password
ADMIN_USERNAME=your_secure_username
ADMIN_PASSWORD=your_secure_password

# 🌐 OLLAMA CONFIGURATION
# URL for local or remote Ollama server
OLLAMA_HOST=http://localhost:11434

# 🔗 CLOUD DATABASE (PostgreSQL/Neon)
# Format: postgresql://user:password@host:port/database?sslmode=require
# Leave empty to use local SQLite
DATABASE_URL=postgresql://your_username:your_password@your_host.neon.tech/your_database?sslmode=require

# 🎟️ API TOKEN
# For remote Ollama authentication
API_TOKEN=your_api_token_here

# 🗄️ LOCAL DATABASE
# SQLite database file name (used when offline or no cloud DB)
SQLITE_DB_FILE=chat_history.db
